{
  "name": "@ix/cli",
  "version": "0.6.1",
  "type": "module",
  "description": "Ix Memory — Persistent Memory for LLM Systems",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./client/*": "./dist/client/*",
    "./cli/*": "./dist/cli/*"
  },
  "bin": {
    "ix": "dist/cli/main.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/build-core-ingestion.mjs && node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "test": "node scripts/build-core-ingestion.mjs && vitest run && node test/parser.smoke.mjs",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke": "node test/parser.smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev": "node scripts/build-core-ingestion.mjs && tsx src/cli/main.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "vite": ">=7.3.2 <8.0.0"
  }
}
